enneagram-test.localhost {
    root * /var/www/html/public
    header /build/assets/* Cache-Control "public, max-age=31536000, immutable"
    php_fastcgi app:9000
    file_server
}

:80 {
  root * /var/www/html/public
  encode zstd gzip
  header /build/assets/* Cache-Control "public, max-age=31536000, immutable"
  php_fastcgi app:9000
  file_server
}
