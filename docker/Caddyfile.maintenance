{$APP_DOMAIN}, {$APP_DOMAIN_WWW}, enneagram-test.{$APP_DOMAIN}, {$ENNEAGRAM_DOMAIN} {
    @www host {$APP_DOMAIN_WWW}
    redir @www https://{$APP_DOMAIN}{uri} permanent

    root * /var/www/html/public
    encode zstd gzip

    # Keep long cache for versioned assets if requested directly
    header /build/assets/* Cache-Control "public, max-age=31536000, immutable"

    # Always serve the static maintenance page with 503 status for all requests.
    handle {
        rewrite * /maintenance.html
        header Cache-Control "no-store"
        file_server
    }
}
